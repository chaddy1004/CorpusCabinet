SERPAPI_KEY=your_serpapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Workspace directory - where ALL data is stored (database + PDFs)
# Examples:
#   ~/Documents/CorpusCabinet
#   /Users/yourname/my-papers
#   ./workspace (relative to project, for development)
WORKSPACE_DIR=./workspace

# Docker only: where workspace maps on HOST machine (defaults to WORKSPACE_DIR)
HOST_WORKSPACE_DIR=${WORKSPACE_DIR}
